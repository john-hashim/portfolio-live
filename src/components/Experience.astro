---
import { siteConfig } from "../config";
const hasExperience = siteConfig.experience && siteConfig.experience.length > 0;
---

{
  hasExperience && (
    <section id="experience" class="px-4 sm:px-24 md:px-40 lg:px-56 py-8 sm:py-12 md:py-16 lg:py-24">
      <div>
        <div class="flex flex-col gap-8 items-start">
          <div>
            <h2 class="text-xl font-bold text-gray-900">
              Experience
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="w-full">
            <div class="space-y-8">
              {siteConfig.experience.map((exp) => (
                <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 p-4 sm:p-6 md:p-8">
                  <div class="mb-4">
                    <div class="flex items-baseline flex-wrap gap-x-3">
                      <h3 class="text-base font-bold text-gray-900">
                        {exp.title}
                      </h3>
                      <span class="text-xs text-gray-500">
                        {exp.dateRange}
                      </span>
                    </div>
                    <p class="text-sm sm:text-base text-gray-700">
                      {exp.company}
                    </p>
                  </div>

                  <ul class="space-y-2">
                    {exp.bullets.map((bullet) => (
                      <li class="flex items-start">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                        <span class="text-xs sm:text-sm text-gray-600">
                          {bullet}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
