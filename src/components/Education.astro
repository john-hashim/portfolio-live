---
import { siteConfig } from "../config";
const hasEducation = siteConfig.education && siteConfig.education.length > 0;
---

{
  hasEducation && (
    <section id="education" class="px-4 sm:px-24 md:px-40 lg:px-56 pt-0 pb-8 sm:pb-12 md:pb-16 lg:pb-24">
      <div>
        <div class="flex flex-col gap-8 items-start">
          <div>
            <h2 class="text-xl font-bold text-gray-900">
              Education
            </h2>
            <div
              class="w-[75px] h-[5px] mt-2 rounded-full"
              style={`background-color: ${siteConfig.accentColor}`}
            />
          </div>

          <div class="w-full">
            <div class="space-y-8">
              {siteConfig.education.map((edu) => (
                <div class="bg-white rounded-xl sm:rounded-2xl border border-gray-200 p-4 sm:p-6 md:p-8">
                  <div class="mb-4">
                    <div class="flex items-baseline flex-wrap gap-x-3">
                      <h3 class="text-base font-bold text-gray-900">
                        {edu.degree}
                      </h3>
                      <span class="text-xs text-gray-500">
                        {edu.dateRange}
                      </span>
                    </div>
                    <p class="text-sm sm:text-base text-gray-700">
                      {edu.school}
                    </p>
                    {edu.university && (
                      <p class="text-xs sm:text-sm text-gray-500">
                        {edu.university}
                      </p>
                    )}
                  </div>

                  {edu.description && (
                    <p class="text-xs sm:text-sm text-gray-600 mb-4">
                      {edu.description}
                    </p>
                  )}

                  <ul class="space-y-2">
                    {edu.achievements.map((achievement) => (
                      <li class="flex items-start">
                        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gray-400 mt-2 mr-3 flex-shrink-0" />
                        <span class="text-xs sm:text-sm text-gray-600">
                          {achievement}
                        </span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>
  )
}
